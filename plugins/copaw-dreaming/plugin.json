{"id": "copaw-dreaming", "name": "🌙 Dreaming 记忆整合", "version": "0.1.0", "description": "三阶段记忆巩固系统（浅睡→REM→深睡），自动评分、筛选、沉淀高价值记忆。灵感来自 OpenClaw Dreaming。", "author": "CoPaw Community", "license": "MIT", "entry": "plugin.py", "capabilities": ["memory_consolidation", "cron_scheduling", "control_command", "startup_hook"], "config_schema": {"type": "object", "properties": {"min_score": {"type": "number", "default": 0.8, "description": "最低综合得分门槛"}, "min_recall_count": {"type": "integer", "default": 3, "description": "最少召回次数门槛"}, "min_unique_queries": {"type": "integer", "default": 3, "description": "最少独立查询数门槛"}, "schedule_enabled": {"type": "boolean", "default": true, "description": "是否启用定时调度"}, "schedule_cron": {"type": "string", "default": "0 2 * * *", "description": "Cron 表达式"}, "schedule_timezone": {"type": "string", "default": "Asia/Shanghai", "description": "时区"}, "memory_dir": {"type": "string", "default": ".workbuddy/memory", "description": "记忆目录相对路径"}, "dry_run": {"type": "boolean", "default": false, "description": "模拟运行模式（不实际写入）"}}, "required": []}, "permissions": ["memory:read", "memory:write", "cron:register", "command:register", "hook:register"], "dependencies": [], "hybrid_mode": true}